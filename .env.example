# Copy this file to ".env" and fill in your values.

# --- OpenRouter (LLM extraction + answering) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=~anthropic/claude-haiku-latest

# --- Neo4j AuraDB Free ---
# From the AuraDB console: when you create an instance you get a
# connection URI (neo4j+s://xxxx.databases.neo4j.io), username (neo4j),
# and a generated password (download/save it - shown only once).
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-generated-password
